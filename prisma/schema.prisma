generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  founder
  admin
  viewer
}

enum Status {
  pending
  approved
  rejected
  archived
}

enum Stage {
  idea
  mvp
  growth
  scale
}

enum PostStatus {
  draft
  published
  archived
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  role          Role      @default(founder)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  startups      Startup[]
  organizations Organization[]
  posts         Post[]
  bookmarks     Bookmark[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Startup {
  id          String   @id @default(cuid())
  founderId   String   @map("founder_id")
  name        String
  slug        String   @unique
  tagline     String?
  description String?  @db.Text
  logoUrl     String?  @map("logo_url")
  coverUrl    String?  @map("cover_url")
  websiteUrl  String?  @map("website_url")
  category    String?
  categories  Json     @default("[]")
  stage       Stage?
  foundedYear Int?     @map("founded_year")
  location    String   @default("Ogun State, Nigeria")
  lga         String?
  isHiring    Boolean  @default(false) @map("is_hiring")
  status      Status   @default(pending)
  isFeatured  Boolean  @default(false) @map("is_featured")
  tags        Json     @default("[]")
  socialLinks Json     @default("{}") @map("social_links")
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  founder   User             @relation(fields: [founderId], references: [id])
  products  StartupProduct[]
  bookmarks Bookmark[]
  posts     Post[]

  @@fulltext([name, tagline, description])
  @@map("startups")
}

model StartupProduct {
  id          String   @id @default(cuid())
  startupId   String   @map("startup_id")
  name        String
  description String?  @db.Text
  imageUrl    String?  @map("image_url")
  url         String?  @map("product_url")
  price       Decimal? @db.Decimal(10, 2)
  currency    String   @default("NGN")
  createdAt   DateTime @default(now()) @map("created_at")

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("startup_products")
}

model Organization {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  name        String
  slug        String   @unique
  tagline     String?
  description String?  @db.Text
  logoUrl     String?  @map("logo_url")
  coverUrl    String?  @map("cover_url")
  websiteUrl  String?  @map("website_url")
  orgType     String?  @map("org_type")
  lga         String?
  foundedYear Int?     @map("founded_year")
  status      Status   @default(pending)
  tags        Json     @default("[]")
  socialLinks Json     @default("{}") @map("social_links")
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id])

  @@fulltext([name, tagline, description])
  @@map("organizations")
}

model Post {
  id            String     @id @default(cuid())
  authorId      String     @map("author_id")
  title         String
  slug          String     @unique
  excerpt       String?
  content       String     @db.LongText
  coverImageUrl String?    @map("cover_image_url")
  category      String
  tags          Json       @default("[]")
  status        PostStatus @default(draft)
  featured      Boolean    @default(false)
  startupId     String?    @map("startup_id")
  publishedAt   DateTime?  @map("published_at")
  viewCount     Int        @default(0) @map("view_count")
  readTimeMins  Int?       @map("read_time_mins")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  author  User     @relation(fields: [authorId], references: [id])
  startup Startup? @relation(fields: [startupId], references: [id])

  @@fulltext([title, excerpt, content])
  @@map("posts")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  startupId String   @map("startup_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([userId, startupId])
  @@map("bookmarks")
}
